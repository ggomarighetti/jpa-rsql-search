{
  "perspectives": [
    {
      "label": "v2-maven-reactor",
      "description": "Direct v2 module DAG for the publishable jpa-rsql-search reactor.",
      "groups": [
        {
          "label": "api",
          "patterns": [
            "jpa-rsql-search-api/src/main/java/**"
          ]
        },
        {
          "label": "rsql-spi",
          "patterns": [
            "jpa-rsql-search-rsql-spi/src/main/java/**"
          ]
        },
        {
          "label": "core",
          "patterns": [
            "jpa-rsql-search-core/src/main/java/**"
          ]
        },
        {
          "label": "jpa-validation",
          "patterns": [
            "jpa-rsql-search-jpa-validation/src/main/java/**"
          ]
        },
        {
          "label": "perplexhub",
          "patterns": [
            "jpa-rsql-search-perplexhub/src/main/java/**"
          ]
        },
        {
          "label": "spring-boot-starter",
          "patterns": [
            "jpa-rsql-search-spring-boot-starter/src/main/java/**"
          ]
        }
      ],
      "constraints": [
        {
          "from": [
            "rsql-spi",
            "core",
            "jpa-validation",
            "perplexhub",
            "spring-boot-starter"
          ],
          "to": [
            "api"
          ],
          "relation": "exclusive-allow"
        },
        {
          "from": [
            "core",
            "perplexhub",
            "spring-boot-starter"
          ],
          "to": [
            "rsql-spi"
          ],
          "relation": "exclusive-allow"
        },
        {
          "from": [
            "jpa-validation",
            "perplexhub",
            "spring-boot-starter"
          ],
          "to": [
            "core"
          ],
          "relation": "exclusive-allow"
        },
        {
          "from": [
            "spring-boot-starter"
          ],
          "to": [
            "jpa-validation"
          ],
          "relation": "exclusive-allow"
        },
        {
          "from": [
            "spring-boot-starter"
          ],
          "to": [
            "perplexhub"
          ],
          "relation": "exclusive-allow"
        },
        {
          "from": [
            "api",
            "rsql-spi",
            "core",
            "jpa-validation",
            "perplexhub"
          ],
          "to": [
            "spring-boot-starter"
          ],
          "relation": "deny"
        }
      ]
    }
  ]
}
